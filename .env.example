# ────────────────────────────────────────────
# BIH E-Commerce Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ────────────────────────────────────────────

# Stripe — Front-end publishable key (safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe — Server-side secret key (Netlify Function only, NEVER in front-end)
STRIPE_SECRET_KEY=sk_test_...

# Manitoulin Transport API (placeholder — add token when available)
# MANITOULIN_API_TOKEN=
